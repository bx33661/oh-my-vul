{
  "name": "oh-my-vul",
  "version": "0.7.1",
  "description": "LLM-friendly vulnerability research skills for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "omv": "dist/cli/omv.js"
  },
  "scripts": {
    "build": "tsc && node -e \"import('fs').then(fs => fs.chmodSync('dist/cli/omv.js', 0o755))\"",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/**/__tests__/*.test.js",
    "sync-assets": "python3 scripts/sync_skill_assets.py",
    "sync-metadata": "python3 scripts/sync_metadata.py",
    "validate": "npm run build && npm test && python3 scripts/release_check.py",
    "setup": "node dist/cli/omv.js setup",
    "doctor": "node dist/cli/omv.js doctor"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/cli/*.d.ts",
    "dist/cli/*.d.ts.map",
    "dist/cli/*.js",
    "dist/cli/*.js.map",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js",
    "dist/index.js.map",
    "skills/",
    "shared/",
    "contracts/",
    "agents/",
    "registry.yaml"
  ],
  "keywords": [
    "claude-code",
    "security",
    "vulnerability",
    "cve",
    "vuldb",
    "skills"
  ],
  "author": "bx33661",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bx33661/oh-my-vul.git",
    "homepage": "https://github.com/bx33661/oh-my-vul#readme",
    "bugs": "https://github.com/bx33661/oh-my-vul/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5",
    "picocolors": "^1.1.1",
    "string-width": "^8.2.1",
    "wrap-ansi": "^10.0.0",
    "yaml": "^2.8.3"
  }
}
