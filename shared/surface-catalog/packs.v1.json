      "guards": ["strict sanitizer config", "escaping", "safe renderer mode", "disabled raw HTML"],
      "false_positive_checks": ["safe markdown renderers that escape raw HTML by default"]
    },
    {
      "id": "template-engine",
      "title": "Dynamic template evaluation",
      "vulnerability_classes": ["ssti", "injection", "sandbox", "xss"],
