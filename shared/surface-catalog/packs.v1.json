{
  "schema_version": "1",
  "catalog_version": "1",
  "packs": [
    {
      "id": "archive-extractor",
      "title": "Archive extraction path and size handling",
      "vulnerability_classes": ["path-traversal", "traversal", "race", "overflow", "unsafe"],
      "discovery_hints": ["zip", "tar", "unzip", "extract", "archive", "package importer"],
      "sources": ["archive entry names", "filenames", "symlinks", "external size fields"],
      "sinks": ["filesystem writes", "path joins", "extraction helpers", "allocation from entry size"],
      "guards": ["normalize and base-prefix check", "reject absolute paths", "symlink policy", "checked sizes"],
      "false_positive_checks": ["packages that only read archives without writing files"]
    },
    {
      "id": "renderer-pipeline",
